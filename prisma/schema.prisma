// Prisma Schema for Thai Mutual Fund Research Dashboard
// Database: PostgreSQL (Neon via Vercel Marketplace)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// AMC (Asset Management Company)
// ─────────────────────────────────────────────
model Amc {
  id        Int      @id @default(autoincrement())
  uniqueId  String   @unique // SEC unique_id
  slug      String?  @unique // URL-friendly slug e.g. "krungsri"
  nameTh    String
  nameEn    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  funds Fund[]

  @@map("amc")
}

// ─────────────────────────────────────────────
// Fund (Project / กองทุน)
// ─────────────────────────────────────────────
model Fund {
  id             Int      @id @default(autoincrement())
  projId         String   @unique // SEC proj_id — used in NAV API
  projAbbrName   String?  // SEC proj_abbr_name from Factsheet
  nameTh         String
  nameEn         String?
  fundStatus     String?  // e.g. "RDY" = ready, "LIQ" = liquidated
  uniqueId       String?  // AMC unique_id reference
  amcId          Int?
  fundType       String?  // e.g. "EQUITY", "FIXED_INCOME", "MIXED"
  riskLevel      Int?     // 1-8 scale per Thai SEC
  dividendPolicy    String?  // e.g. "PAID", "ACCUMULATE"
  regisDate         DateTime? @db.Date // SEC regis_date — fund inception / registration date
  // Fee fields from SEC /FundFactsheet/fund/{proj_id}/fee — updated by backfill-fees.ts
  frontEndFee       Decimal? @db.Decimal(6, 4) // ค่าธรรมเนียมการขายหน่วยลงทุน actual charged %
  backEndFee        Decimal? @db.Decimal(6, 4) // ค่าธรรมเนียมการรับซื้อคืน actual charged %
  managementFee     Decimal? @db.Decimal(6, 4) // ค่าธรรมเนียมการจัดการ actual charged %
  totalExpenseRatio Decimal? @db.Decimal(6, 4) // ค่าธรรมเนียมและค่าใช้จ่ายรวมทั้งหมด actual %
  investmentPolicy  String?  // investment_policy_desc decoded from SEC /policy endpoint
  // Asset allocation, benchmark, SEC performance — updated by backfill-sec-performance.ts
  assetAllocation   Json?    // [{asset_name: string, asset_ratio: string}] from /asset
  benchmark         String?  // primary benchmark name(s) from /benchmark, joined with " · "
  secReturnYtd      Decimal? @db.Decimal(10, 4) // SEC-reported YTD return %
  createdAt         DateTime @default(now())
  updatedAt      DateTime @updatedAt

  amc         Amc?         @relation(fields: [amcId], references: [id])
  fundClasses FundClass[]
  navPrices   NavPrice[]
  fundMetrics FundMetric[]

  @@index([projAbbrName])
  @@index([nameTh])
  @@index([fundType])
  @@index([riskLevel])
  @@index([fundStatus])
  // Compound indexes for filtered list queries
  @@index([fundStatus, fundType])   // /api/funds?fundType=EQ (most common filter)
  @@index([fundStatus, amcId])      // /api/funds?amcId=X (AMC fund list)
  @@map("fund")
}

// ─────────────────────────────────────────────
// FundClass (กองทุนชั้นที่ — e.g. A, B, D)
// NOTE: class_abbr_name in DailyInfo ≠ proj_abbr_name in Factsheet
//       We store all classes returned by DailyInfo and mark one default.
//       Default rule: prefer class with "A" suffix, else first alphabetically.
// ─────────────────────────────────────────────
model FundClass {
  id            Int      @id @default(autoincrement())
  fundId        Int
  classAbbrName String   // e.g. "KFFLEX-A", "KFFLEX-D"
  className     String?  // full class name
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  fund        Fund         @relation(fields: [fundId], references: [id])
  navPrices   NavPrice[]
  fundMetrics FundMetric[]

  @@unique([fundId, classAbbrName])
  @@index([fundId])
  @@index([fundId, isDefault]) // speeds up "get default class for fund" queries
  @@map("fund_class")
}

// ─────────────────────────────────────────────
// NavPrice (ราคา NAV รายวัน)
// ─────────────────────────────────────────────
model NavPrice {
  id          Int      @id @default(autoincrement())
  fundId      Int
  fundClassId Int
  navDate     DateTime @db.Date
  lastVal     Decimal  @db.Decimal(18, 6) // NAV per unit
  buyPrice    Decimal? @db.Decimal(18, 6)
  sellPrice   Decimal? @db.Decimal(18, 6)
  netAsset    Decimal? @db.Decimal(20, 2) // Total AUM in THB (net_asset from SEC NAV API)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  fund      Fund      @relation(fields: [fundId], references: [id])
  fundClass FundClass @relation(fields: [fundClassId], references: [id])

  @@unique([fundClassId, navDate])
  @@index([fundId])
  @@index([fundClassId])
  @@index([navDate])
  // Compound indexes for common query patterns
  @@index([fundClassId, navDate(sort: Desc)]) // "latest 2 NAVs for a class" — movers + detail page
  @@index([navDate, fundClassId])              // "all fund NAVs on a given date" — movers query
  @@map("nav_price")
}

// ─────────────────────────────────────────────
// FundMetric (pre-computed performance metrics)
// ─────────────────────────────────────────────
model FundMetric {
  id                      Int      @id @default(autoincrement())
  fundId                  Int
  fundClassId             Int
  period                  String   // "1M" | "3M" | "6M" | "1Y" | "3Y" | "5Y" | "MAX"
  startDate               DateTime @db.Date
  endDate                 DateTime @db.Date
  returnPct               Decimal? @db.Decimal(10, 4)
  annualizedVolatilityPct Decimal? @db.Decimal(10, 4)
  maxDrawdownPct          Decimal? @db.Decimal(10, 4)
  sharpeRatio             Decimal? @db.Decimal(10, 4)
  navCount                Int?     // number of NAV data points used
  calculatedAt            DateTime @default(now())
  // SEC-reported figures from /performance — updated by backfill-sec-performance.ts
  secReturnPct            Decimal? @db.Decimal(10, 4) // SEC official fund return for period
  secBenchmarkReturnPct   Decimal? @db.Decimal(10, 4) // benchmark return for period
  secPeerAvgReturnPct     Decimal? @db.Decimal(10, 4) // peer group average return for period

  fund      Fund      @relation(fields: [fundId], references: [id])
  fundClass FundClass @relation(fields: [fundClassId], references: [id])

  @@unique([fundClassId, period, endDate])
  @@index([fundId])
  @@index([fundClassId])
  @@index([period])
  // Compound indexes — critical for rankings (period filter + metric sort)
  @@index([period, returnPct(sort: Desc)])          // rankings by return (most common)
  @@index([period, annualizedVolatilityPct])         // rankings by volatility
  @@index([period, maxDrawdownPct])                  // rankings by drawdown
  @@index([period, sharpeRatio])                     // rankings by Sharpe
  @@index([fundClassId, period])                     // per-fund metric lookup on detail page
  @@map("fund_metric")
}

// ─────────────────────────────────────────────
// SyncLog (audit trail for cron jobs)
// ─────────────────────────────────────────────
model SyncLog {
  id               Int       @id @default(autoincrement())
  jobType          String    // "DAILY_SYNC" | "MANUAL_SYNC" | "METRIC_CALC"
  status           String    // "RUNNING" | "SUCCESS" | "FAILED" | "PARTIAL"
  message          String?
  recordsProcessed Int?
  startedAt        DateTime  @default(now())
  finishedAt       DateTime?

  @@index([jobType])
  @@index([startedAt])
  @@index([status]) // homepage queries SyncLog by status
  @@map("sync_log")
}

// ─────────────────────────────────────────────
// BankRate (Thai bank deposit interest rates)
// Updated via scripts/update-bank-rates.ts
// Sources: individual bank websites / BOT publications
// ─────────────────────────────────────────────
model BankRate {
  id          Int      @id @default(autoincrement())
  bankName    String   // Thai name e.g. "กสิกรไทย"
  bankAbbr    String   // English abbr e.g. "KBank"
  productType String   // "SDA" = savings, "FD12" = fixed 12-month
  ratePct     Decimal  @db.Decimal(6, 4) // interest rate in %
  verifiedAt  DateTime @db.Date // date this rate was last confirmed
  sourceUrl   String?  // URL to bank's published rate page

  @@unique([bankAbbr, productType])
  @@index([productType])
  @@map("bank_rate")
}

// ─────────────────────────────────────────────
// SearchLog (anonymous usage analytics)
// IMPORTANT: No IP address or personal data stored
// ─────────────────────────────────────────────
model SearchLog {
  id          Int      @id @default(autoincrement())
  query       String
  resultCount Int
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@map("search_log")
}
