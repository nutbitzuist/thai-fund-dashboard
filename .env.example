# ─────────────────────────────────────────────
# Thai Mutual Fund Research Dashboard
# Environment Variables Template
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# ── Database (Neon PostgreSQL via Vercel Marketplace) ─
# Get from: Vercel Dashboard → Storage → Neon → Connect
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ── SEC Open API Keys ─────────────────────────
# Register at: https://developer.sec.or.th
# IMPORTANT: Do NOT prefix with NEXT_PUBLIC_ — these are server-side only
SEC_API_KEY="your-sec-factsheet-api-key-here"
SEC_NAV_API_KEY="your-sec-nav-api-key-here"

# ── Cron Secret ───────────────────────────────
# Generate with: openssl rand -hex 32
# Used to protect /api/sync/daily endpoint
CRON_SECRET="your-random-32-char-secret-here"

# ── App URL ───────────────────────────────────
# Your Vercel deployment URL
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# ── Optional: Risk-Free Rate ──────────────────
# Default is 0.015 (1.5% per year) for Sharpe Ratio calculation
# RISK_FREE_RATE="0.015"
